# =========================
# Application
# =========================
APP_NAME=mypiggybankmobile-api
ENV=development

# =========================
# JWT Authentication
# =========================
# CHANGE THIS in production
JWT_SECRET=flag{dont_commit_secrets7211}
JWT_ALG=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# =========================
# Database
# =========================
# Local SQLite (default)
DATABASE_URL=sqlite:///./mypiggybank.db

# Example PostgreSQL (production)
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/mypiggybank

# =========================
# CORS (comma-separated)
# =========================
CORS_ORIGINS=http://localhost:19006,http://localhost:8081,http://localhost:3000

# =========================
# Optional Security Enhancements
# =========================
# If you later add refresh tokens:
# REFRESH_TOKEN_EXPIRE_DAYS=7

# If deploying behind HTTPS proxy:
# FORCE_HTTPS=true